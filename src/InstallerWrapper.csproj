<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <SelfContained>false</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishTrimmed>false</PublishTrimmed>
    <AssemblyName>PracticePerfect-Installer</AssemblyName>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <ProductVersion>1.0.0</ProductVersion>
    <InformationalVersion>1.0.0</InformationalVersion>
    <Company>Practice Perfect</Company>
    <Product>Practice Perfect Email Router Installer</Product>
    <Description>One-click installer for Practice Perfect Email Router</Description>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- Bundle the PowerShell script in the output directory -->
  <ItemGroup>
    <None Include="../proxy_installer.ps1">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>proxy_installer.ps1</Link>
    </None>
  </ItemGroup>

</Project>
